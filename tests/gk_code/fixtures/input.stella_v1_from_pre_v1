
!================================================================================
!=================================== Geometry ===================================
!================================================================================

&geometry_options
  geometry_option = 'miller'
/

&geometry_miller
  betadbprim = 0.0
  betaprim = 0.0
  d2psidr2 = 0.0
  d2qdr2 = 0.0
  kappa = 1.0
  kapprim = 0.0
  nzed_local = 128
  qinp = 1.4
  rgeo = 3.0
  rhoc = 0.55
  rmaj = 3.0
  shat = 0.8
  shift = 0.0
  tri = 0.0
  triprim = 0.0
/


!================================================================================
!=================================== Physics ====================================
!================================================================================

&gyrokinetic_terms
  include_nonlinear = .false.
  simulation_domain = 'fluxtube'
/

&scale_gyrokinetic_terms
  fphi = 1.0
/

&physics_inputs
  rhostar = 0.0
/

&electromagnetic
  beta = 0.01
/


!================================================================================
!================================= Diagnostics ==================================
!================================================================================

&diagnostics
  nsave = 10000
  nwrite = 1000
  save_for_restart = .false.
/


!================================================================================
!=========================== Initialise Distribution ============================
!================================================================================

&initialise_distribution
  initialise_distribution_option = 'default'
  phiinit = 0.001
/

&initialise_distribution_maxwellian
  chop_side = .false.
  width0 = 1.0
/

&initialise_distribution_noise
  chop_side = .false.
/

&initialise_distribution_kpar
  chop_side = .false.
  width0 = 1.0
/

&restart_options
  restart_file = 'nc/example.nc'
/


!================================================================================
!====================== Ion, electron and impurity species ======================
!================================================================================

&species_options
  nspec = 2
  species_option = 'stella'
/

&adiabatic_electron_response
  adiabatic_option = 'field-line-average-term'
/

&species_parameters_1
  dens = 1.0
  fprim = 0.733
  mass = 0.00027
  temp = 1.0
  tprim = 2.3
  type = 'electron'
  z = -1.0
/

&species_parameters_2
  dens = 1.0
  fprim = 0.733
  mass = 1.0
  temp = 1.0
  tprim = 2.3
  type = 'ion'
  z = 1.0
/


!================================================================================
!====================== Discretized (kx,ky,z,mu,vpa) grid =======================
!================================================================================

&kxky_grid_option
  grid_option = 'range'
/

&kxky_grid_range
  aky_max = 0.5
  aky_min = 0.5
  naky = 1
  theta0_max = 0.0
  theta0_min = 0.0
/

&z_grid
  nperiod = 2
  ntubes = 1
  nzed = 24
/

&z_boundary_condition
  boundary_option = 'default'
/

&velocity_grids
  nmu = 12
  nvgrid = 18
  vpa_max = 3.0
/


!================================================================================
!=================================== Numerics ===================================
!================================================================================

&time_trace_options
  nstep = 10000
/

&time_step
  delt = 0.01
  delt_max = 1.0
  delt_min = 1e-10
/

&numerical_algorithms
  drifts_implicit = .false.
  mirror_implicit = .true.
  mirror_semi_lagrange = .false.
  stream_implicit = .true.
/

&numerical_upwinding_for_derivatives
  time_upwind = 0.0
  vpa_upwind = 0.0
  zed_upwind = 0.0
/


!================================================================================
!================================= Dissipation ==================================
!================================================================================

&dissipation_and_collisions_options
  collision_model = 'dougherty'
  collisions_implicit = .true.
  hyper_dissipation = .false.
  include_collisions = .false.
  vnew_ref = 0.0
  zeff = 1.0
/

&hyper_dissipation
  d_hyper = 0.0
/


!================================================================================
!================================= Neoclassics ==================================
!================================================================================

&neoclassical_input
  include_neoclassical_terms = .false.
  neo_option = 'sfincs'
/

&sfincs_input
  nproc_sfincs = 2
  nx = 5
  nxi = 16
/


!================================================================================
!=============================== Radial variation ===============================
!================================================================================


!================================================================================
!=============================== Parallelisation ================================
!================================================================================

&parallelisation
  vms_layout = 'vms'
  xyzs_layout = 'yxzs'
/


